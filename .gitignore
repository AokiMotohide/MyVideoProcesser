# ==========================================
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.db
*.opendb
*.tlog
*.recipe
*.lastbuildstate
*.idb
*.pdb
*.ilk

# ==========================================
# 4. Compiled Binaries & Objects
# ==========================================
*.exe
*.dll
*.lib
*.a
*.o
*.obj
*.so
*.dylib
*.exp
*.res
*.pch

# ==========================================

# ==========================================
# 1. Build & Dependency Directories
# ==========================================
# CMakeのビルド出力とFetchContentなどの依存先を完全に除外
[Bb]uild/
[Oo]ut/
_deps/
.vs/
bin/
x64/
x86/

# ==========================================
# 2. CMake Generated (Root/Intermediate)
# ==========================================
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
cmake_uninstall.cmake
Makefile
install_manifest.txt
compile_commands.json
# FetchContent用
*-populate.*

# ==========================================
